{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without token — forbidden",
      "method": "GET",
      "path": "/",
      "expectedStatus": 403,
      "expectedBody": {"error": "Forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST without token — forbidden",
      "method": "POST",
      "path": "/",
      "body": {"s3_key": "test.txt"},
      "expectedStatus": 403,
      "expectedBody": {"error": "Forbidden"},
      "bodyMatcher": "partial"
    }
  ]
}
